{
  "name": "lab03-pair04-notification",
  "version": "1.0.0",
  "description": "Lab 03 - Notification Service (Pair 04 - Queue Async) dựa trên negotiation-log.md",
  "scripts": {
    "lint": "npx @stoplight/spectral-cli lint contracts/*.yaml",
    "mock": "npx prism mock contracts/notification.openapi.yaml --port 4010",
    "test:mock": "npx newman run postman/collections/notification.postman_collection.json -e postman/environments/notification_mock.postman_environment.json -r cli,junit --reporter-junit-export reports/newman-report-mock.xml",
    "test:local": "npx newman run postman/collections/notification.postman_collection.json -e postman/environments/notification_local.postman_environment.json -r cli,junit --reporter-junit-export reports/newman-report-local.xml",
    "test:queue": "npx jest test/queue-contract.test.js --coverage",
    "test:all": "npm run test:queue && npm run test:mock",
    "html:test": "npx newman run postman/collections/notification.postman_collection.json -e postman/environments/notification_mock.postman_environment.json -r htmlextra --reporter-htmlextra-export reports/newman-report.html"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.8.0",
    "@stoplight/spectral-cli": "^6.11.0",
    "jest": "^29.7.0",
    "newman": "^6.1.0"
  }
}